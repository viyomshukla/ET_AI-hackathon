# Copy this file to ".env" (Vite auto-loads it). All Vite env vars must
# start with VITE_ to be exposed to the browser code.

# Local dev: your FastAPI server (uvicorn main:app --reload) usually runs here.
# After deploying the backend to Render, change this to your Render URL,
# e.g. https://your-app.onrender.com
VITE_API_URL=http://localhost:8000
