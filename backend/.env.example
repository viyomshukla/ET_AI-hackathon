# Copy this file to ".env" and fill in your own keys.
# Never commit the real ".env" file to git.

# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Get these from your Supabase project settings > API
# SUPABASE_URL looks like: https://xxxxxxxxxxxx.supabase.co
# SUPABASE_KEY should be the "service_role" key (backend only, keep it secret!)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# Comma separated list of frontend origins allowed to call this API.
# For local dev, the Vite default is http://localhost:5173
# Add your Vercel URL here after you deploy the frontend.
FRONTEND_ORIGINS=http://localhost:5173
